; ==============================================
; M5Claw 用户配置文件
; ==============================================
; 使用方法：
;   1. 复制此文件为 user_config.ini
;   2. 填入你的配置
;   3. 运行 flash.py，或至少执行：
;      pio run -t upload
;      pio run -t uploadfs
;   配置会先写入 SPIFFS 的引导文件，并在首次启动时导入到设备 NVS 后删除
;
; 注意：user_config.ini 已在 .gitignore 中，不会上传到 GitHub
; ==============================================

[user]
; WiFi 配置（必填）
wifi_ssid = 
wifi_pass = 

; Xiaomi MiMo 配置（必填）
; 文档：https://platform.xiaomimimo.com/#/docs/quick-start/first-api-call
mimo_model = mimo-v2-omni
mimo_api_key = 

; 天气城市（选填，英文）
city = Beijing
