; ==============================================
; M5Claw 用户配置文件
; ==============================================
; 使用方法：
;   1. 复制此文件为 user_config.ini
;   2. 填入你的配置
;   3. 编译烧录：pio run -t upload
;   配置会在首次启动时自动写入设备 NVS
;
; 注意：user_config.ini 已在 .gitignore 中，不会上传到 GitHub
; ==============================================

[user]
; WiFi 配置（必填）
wifi_ssid = 
wifi_pass = 

; LLM 配置（必填其一）
; 支持 anthropic 或 openai
llm_provider = anthropic
llm_model = claude-sonnet-4-20250514
llm_api_key = 

; DashScope 配置（选填，语音识别和语音合成需要）
; 获取地址：https://bailian.console.aliyun.com/#/api-key
dashscope_key = 

; 天气城市（选填，英文）
city = Beijing
